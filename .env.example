# Cliente ativo — slug do YAML em clients/ (ex: deepstrat → clients/deepstrat.yaml)
# Se omitido, usa as variaveis ODOO_* abaixo diretamente.
ODOO_CLIENT=deepstrat

# Odoo — credenciais (usadas como fallback se o YAML do cliente nao preencher)
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database-name
ODOO_LOGIN=your-email@company.com
ODOO_KEY=your-api-key-here

# Clockify (optional — only needed for Clockify integration)
CLOCKIFY_KEY=your-clockify-api-key-here
