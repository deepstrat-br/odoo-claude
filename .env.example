# ─── Credenciais por cliente ──────────────────────────────────────────────────
# Padrao: {SLUG}_ODOO_LOGIN e {SLUG}_ODOO_KEY (slug em maiusculas)
# url e db ficam no clients/<slug>.yaml — aqui apenas os segredos.
#
# Exemplo:
# ACME_ODOO_LOGIN=your-email@acme.com
# ACME_ODOO_KEY=your-api-key-here
#
# CONTOSO_ODOO_LOGIN=your-email@contoso.com
# CONTOSO_ODOO_KEY=your-api-key-here

# ─── Clockify ─────────────────────────────────────────────────────────────────
# Opcional — necessario apenas para a integracao Clockify
CLOCKIFY_KEY=your-clockify-api-key-here
